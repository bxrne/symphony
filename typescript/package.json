{
  "name": "@symphony/typescript",
  "version": "0.1.0",
  "description": "TypeScript reference implementation of the Symphony coding-agent orchestrator",
  "private": true,
  "type": "module",
  "bin": {
    "symphony": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node --enable-source-maps dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'"
  },
  "dependencies": {
    "chokidar": "^4.0.3",
    "js-yaml": "^4.1.0",
    "liquidjs": "^10.20.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  },
  "engines": {
    "node": ">=20"
  }
}
